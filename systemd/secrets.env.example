# Copy to /etc/actual-ai-categorizer/secrets.env (chmod 600).
# These satisfy the ${VAR} placeholders in config.yaml.
ACTUAL_PASSWORD=your-actual-server-password
# Only needed if your budget is end-to-end encrypted:
ACTUAL_E2E_PASSWORD=
# Only needed for cloud AI providers; can be left empty for local llama-server:
AI_API_KEY=
